      },
      "description": "Displays all ERROR and FATAL level logs from the API. Use this to quickly identify critical issues and system failures that need immediate attention.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "dedupStrategy": "none",
        "enableInfiniteScrolling": false,
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showControls": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": 1,
        "unwrappedColumns": false,
        "wrapLogMessage": false
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "direction": "backward",
          "editorMode": "code",
          "expr": "{app=\"coverletter-api\"} | json | level=~\"error|fatal\" | RequestPath!=\"/metrics\" | line_format \"{{.FormattedLog}}\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent Error Logs",
      "type": "logs"
    },
